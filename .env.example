# Copier ce fichier en .env et remplir les clés
# MapTiler : https://cloud.maptiler.com → Dashboard → API Keys
VITE_MAPTILER_KEY=your_maptiler_key_here

# RevenueCat : https://app.revenuecat.com → Project → API Keys
# test_ pour sandbox, goog_ pour production
VITE_REVENUECAT_KEY=your_revenuecat_key_here

# Country Packs : URL publique du catalog.json sur Cloudflare R2
VITE_PACKS_CATALOG_URL=https://your-bucket.r2.dev/catalog.json
