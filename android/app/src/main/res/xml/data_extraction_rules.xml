<?xml version="1.0" encoding="utf-8"?>
<!--
    Règles d'extraction de données Android 12+ (API 31+)
    Remplace fullBackupContent (deprecated sur Android 12+) pour les transferts cloud et ADB.
    Exclut les SharedPreferences (clé MapTiler + préférences utilisateur) des sauvegardes.
    Référence : https://developer.android.com/about/versions/12/backup-restore
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- Exclure toutes les SharedPreferences (clé API MapTiler + snapshots GPS) -->
        <exclude domain="sharedpref" path="." />
    </cloud-backup>
    <device-transfer>
        <!-- Autoriser le transfert appareil-à-appareil des préférences (pratique pour l'utilisateur) -->
        <!-- mais exclure les clés API par précaution -->
        <exclude domain="sharedpref" path="." />
    </device-transfer>
</data-extraction-rules>
