{
  "name": "suntrail_threejs",
  "version": "5.26.9",
  "scripts": {
    "dev": "vite",
    "check": "tsc --noEmit",
    "build": "vite build",
    "test": "vitest run",
    "cap:sync": "npx cap sync",
    "cap:open": "npx cap open android",
    "cap:assets": "npx capacitor-assets generate --android",
    "deploy": "npm run check && npm run build && npm run cap:sync",
    "android:update": "npm run deploy",
    "build-overview": "npx tsx scripts/build-overview-tiles.ts",
    "build-pack": "npx tsx scripts/build-country-pack.ts",
    "audit:i18n": "python audit_i18n.py"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/core": "^8.2.0",
    "@capacitor/filesystem": "^8.1.2",
    "@capacitor/geolocation": "^8.1.0",
    "@capacitor/haptics": "^8.0.1",
    "@capacitor/network": "^8.0.1",
    "@mapbox/vector-tile": "^2.0.4",
    "@revenuecat/purchases-capacitor": "^12.3.0",
    "gpxparser": "^3.0.8",
    "pbf": "^4.0.1",
    "pmtiles": "^4.4.0",
    "suncalc": "^1.9.0",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@aws-sdk/client-s3": "^3.1023.0",
    "@aws-sdk/lib-storage": "^3.1023.0",
    "@capacitor/assets": "^3.0.5",
    "@capacitor/cli": "^8.3.0",
    "@testing-library/dom": "^10.4.1",
    "@types/node": "^25.4.0",
    "@types/suncalc": "^1.9.2",
    "@types/three": "^0.160.0",
    "@vitest/coverage-v8": "^4.1.3",
    "@vitest/ui": "^4.1.3",
    "axe-core": "^4.11.1",
    "dotenv": "^17.4.0",
    "happy-dom": "^20.8.3",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vite": "^8.0.6",
    "vite-plugin-pwa": "^0.19.8",
    "vitest": "^4.1.3"
  },
  "overrides": {
    "vite": "$vite",
    "jsdom": "^25.0.1",
    "qs": "^6.14.1",
    "tough-cookie": "^4.1.3",
    "@xmldom/xmldom": "^0.8.12",
    "tar": "^7.5.11",
    "minimatch": "^3.1.4",
    "serialize-javascript": "^7.0.5"
  }
}
