{
  "name": "suntrail_threejs",
  "version": "1.0.0",
  "scripts": {
    "dev": "vite",
    "check": "tsc --noEmit",
    "build": "vite build",
    "cap:sync": "npx cap sync",
    "cap:open": "npx cap open android",
    "cap:assets": "npx capacitor-assets generate --android",
    "deploy": "npm run check && npm run build && npm run cap:sync",
    "android:update": "npm run deploy"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/geolocation": "^8.1.0",
    "gpxparser": "^3.0.8",
    "suncalc": "^1.9.0",
    "three": "^0.160.0"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@types/node": "^25.4.0",
    "@types/suncalc": "^1.9.2",
    "@types/three": "^0.183.1",
    "typescript": "^5.9.3",
    "vite": "^5.0.0"
  }
}
