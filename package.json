{
  "name": "suntrail_threejs",
  "version": "4.6.0",
  "scripts": {
    "dev": "vite",
    "check": "tsc --noEmit",
    "build": "vite build",
    "test": "vitest run",
    "cap:sync": "npx cap sync",
    "cap:open": "npx cap open android",
    "cap:assets": "npx capacitor-assets generate --android",
    "deploy": "npm run check && npm run build && npm run cap:sync",
    "android:update": "npm run deploy"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/geolocation": "^8.1.0",
    "gpxparser": "^3.0.8",
    "suncalc": "^1.9.0",
    "three": "^0.160.0",
    "three-stdlib": "^2.36.1"
  },
  "devDependencies": {
    "@capacitor/assets": "^3.0.5",
    "@testing-library/dom": "^10.4.1",
    "@types/node": "^25.4.0",
    "@types/suncalc": "^1.9.2",
    "@types/three": "^0.183.1",
    "@vitest/ui": "^4.0.18",
    "happy-dom": "^20.8.3",
    "typescript": "^5.9.3",
    "vite": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
